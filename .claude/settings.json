{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./production-data/**)",
      "Read(./customer-exports/**)",
      "Read(./backups/**)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git push --force *)",
      "Bash(npx supabase db reset *)",
      "Bash(supabase db reset *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npx supabase *)",
      "Bash(supabase *)",
      "Bash(vercel *)"
    ]
  },
  "disableBypassPermissionsMode": "disable"
}
