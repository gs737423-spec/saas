# ---------------------------------------------------------------------------
# Server-only secrets. NONE of these may ever get a VITE_ prefix — a VITE_
# variable is inlined into the frontend bundle and becomes public. Everything
# here is read only inside Vercel Serverless Functions (api/**).
# ---------------------------------------------------------------------------

# Mercado Livre app credentials (developers.mercadolivre.com.br/apps)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Must match EXACTLY the redirect URI registered on the Mercado Livre app.
# Example: https://your-app.vercel.app/api/integrations/mercadolivre/callback
ML_REDIRECT_URI=

# Base URL of this deployment, used to build post-OAuth redirects back into
# the app (e.g. https://your-app.vercel.app). No trailing slash.
APP_BASE_URL=

# Supabase project (server-side only — service role bypasses RLS, never
# expose it to the frontend, never reuse the anon/public key here).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 32-byte key (64 hex chars) used to encrypt access/refresh tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATIONS_ENCRYPTION_KEY=

# Random secret used to sign the OAuth `state` param (CSRF/replay protection).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=

# ---------------------------------------------------------------------------
# Optional DEV/QA-only login (src/contexts/AuthContext.tsx). Off by default —
# only set BOTH vars to enable a demo account. Do NOT set these in the
# Production Vercel environment target: this login check runs entirely
# client-side, so anything set here ends up readable in the shipped JS bundle,
# same as the two hardcoded accounts already in AuthContext.tsx. Fine for
# local .env.local or a Preview deployment used only for internal QA.
#
# Generate the hash for a chosen password with:
#   node -e "const p=require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex');console.log(p)"
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD_HASH=
